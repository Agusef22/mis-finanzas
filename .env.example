# ============================================================
# mis-finanzas — variables de entorno
# ============================================================
# Este archivo es un TEMPLATE sin valores reales. Se sube al repo.
# Copialo así:
#   cp .env.example .env         (edge functions / CLI de supabase)
#   cp .env.example app/.env     (Nuxt — solo usa SUPABASE_URL y SUPABASE_KEY)
# Y completá los valores con TUS credenciales.

# ============================================================
# SUPABASE
# ============================================================
# Proyecto cloud: https://supabase.com/dashboard/project/<ref>/settings/api
# O local: supabase start (imprime estas keys en consola)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_xxx

# Solo para edge functions y scripts server-side. NUNCA al cliente.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ============================================================
# LLM providers (para parser de Telegram)
# ============================================================
# Groq: https://console.groq.com (gratis, primario)
GROQ_API_KEY=gsk_xxx

# OpenRouter (fallback): https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxx

# ============================================================
# Telegram Bot
# ============================================================
# Token: creá un bot con @BotFather en Telegram y te lo da
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Secret random para validar que los webhooks vienen de Telegram
# Generalo con: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ============================================================
# WhatsApp (opcional — si querés activar el bot de WA también)
# ============================================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================================
# Otros
# ============================================================
DOLARAPI_URL=https://dolarapi.com/v1/dolares
